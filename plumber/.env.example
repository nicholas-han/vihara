# Copy to plumber/.env and fill in. .env is gitignored — never commit real keys.

# Use testnet for all calls (default: false)
HL_USE_TESTNET=true

# Testnet-only private key for trading. Use a throwaway/agent wallet, never a
# mainnet wallet holding real funds.
HL_PRIVATE_KEY=0x...

# Optional: when signing with an agent/API wallet on behalf of a main account,
# set the main account's address here.
HL_ACCOUNT_ADDRESS=

# Keep WebSocket off unless you need live feeds (default: true)
HL_SKIP_WS=true
