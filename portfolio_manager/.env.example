# The private data repo root (canonical CSVs + derived build/ artifacts).
# When set, PORTFOLIO_DB_PATH defaults to $VIHARA_DATA_DIR/build/portfolio.sqlite3.
VIHARA_DATA_DIR=~/git/vihara-data

# Optional explicit override of the records database path.
# PORTFOLIO_DB_PATH=/absolute/path/outside/repo/portfolio.db

# Optional. Omit to read these tables from the records database during local v1.
# INSTRUMENT_DB_PATH=/absolute/path/outside/repo/instrument.db
# FINANCIALS_DB_PATH=/absolute/path/outside/repo/financials.db

# Optional override for the HTML/CSS/JS directory.
# PORTFOLIO_STATIC_DIR=/absolute/path/to/static
